<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Founder's Story — The Core</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ========== RESET & BASE ========== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  color: #2D3B2D;
  background: #FAFAF8;
  line-height: 1.7;
  font-weight: 400;
  -webkit-font-smoothing: antialiased;
}
a { text-decoration: none; color: inherit; }
img { max-width: 100%; display: block; }
button { cursor: pointer; border: none; font-family: inherit; }

/* ========== CSS VARIABLES ========== */
:root {
  --sage: #93A99E;
  --mist: #EDF3F0;
  --sand: #EDF3F0;
  --taupe: #D5C7AD;
  --forest: #2D3B2D;
  --deep-sage: #6B604D;
  --white: #FFFFFF;
  --off-white: #FAFAF8;
  --max-width: 1200px;
  --heading-font: 'Bodoni Moda', serif;
  --body-font: 'DM Sans', sans-serif;
}

/* ========== TYPOGRAPHY ========== */
h1, h2, h3, h4 { font-family: var(--heading-font); font-weight: 400; line-height: 1.25; }
.section-label {
  font-family: var(--body-font);
  font-size: 12px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--sage);
  margin-bottom: 16px;
}

/* ========== BUTTONS ========== */
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--sage);
  color: white;
  font-family: var(--body-font);
  font-size: 16px;
  font-weight: 500;
  padding: 16px 40px;
  border-radius: 999px;
  transition: all 0.3s ease;
}
.btn-primary:hover { background: #7E9A8C; transform: scale(1.02); }

/* ========== NAVIGATION ========== */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 0 48px;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(213,199,173,0.2);
  transition: all 0.3s ease;
}
.navbar-logo {
  font-family: var(--heading-font);
  font-size: 28px;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: var(--forest);
}
.navbar-links {
  display: flex;
  align-items: center;
  gap: 36px;
}
.navbar-links a {
  font-size: 14px;
  font-weight: 500;
  color: var(--forest);
  transition: color 0.2s;
  position: relative;
}
.navbar-links a:hover, .navbar-links a.active { color: var(--sage); }
.navbar-links a.active::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  right: 0;
  height: 1.5px;
  background: var(--sage);
}
.nav-cta {
  background: var(--sage);
  color: white;
  font-size: 14px;
  font-weight: 500;
  padding: 12px 32px;
  border-radius: 999px;
  transition: background 0.3s;
}
.nav-cta:hover { background: #7E9A8C; }

/* ========== FOUNDER HERO ========== */
.founder-hero {
  width: 100%;
  padding: 160px 48px 80px;
  background: var(--sand);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.founder-hero-inner {
  max-width: var(--max-width);
  margin: 0 auto;
}
.founder-photo-placeholder {
  width: 600px;
  max-width: 100%;
  aspect-ratio: 3/4;
  background: linear-gradient(135deg, rgba(147,169,158,0.2), rgba(147,169,158,0.1));
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--sage);
  font-size: 16px;
  font-weight: 500;
  letter-spacing: 0.08em;
  margin: 0 auto 48px;
}
.founder-label {
  font-family: var(--body-font);
  font-size: 12px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--sage);
  margin-bottom: 16px;
}
.founder-hero h1 {
  font-family: var(--heading-font);
  font-size: 48px;
  font-weight: 400;
  color: var(--forest);
  margin-bottom: 12px;
}
.founder-subtitle {
  font-family: var(--body-font);
  font-size: 16px;
  font-weight: 400;
  color: var(--deep-sage);
}

/* ========== RASHI'S STORY SECTION ========== */
.story-section {
  width: 100%;
  padding: 100px 48px;
  background: var(--sand);
}
.story-inner {
  max-width: 720px;
  margin: 0 auto;
}
.story-text {
  font-family: var(--body-font);
  font-size: 16px;
  color: var(--forest);
  line-height: 1.8;
}
.story-text p {
  margin-bottom: 24px;
}
.story-quote {
  font-family: var(--heading-font);
  font-size: 32px;
  font-style: italic;
  color: var(--sage);
  text-align: center;
  padding: 48px 0;
  margin: 48px 0;
  position: relative;
}
.story-quote::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 1px;
  background: var(--taupe);
}
.story-quote::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 1px;
  background: var(--taupe);
}
.story-text em {
  font-family: var(--heading-font);
  font-style: italic;
  font-weight: 400;
  color: inherit;
}

/* ========== CTA SECTION ========== */
.cta-hero {
  width: 100%;
  padding: 120px 48px;
  background: var(--white);
}
.cta-hero-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  text-align: center;
}
.cta-hero h2 {
  font-family: var(--heading-font);
  font-size: 36px;
  font-weight: 400;
  color: var(--forest);
  margin-bottom: 16px;
}
.cta-hero p {
  font-family: var(--body-font);
  font-size: 16px;
  color: var(--deep-sage);
  margin-bottom: 32px;
}

/* ========== FOOTER ========== */
.footer {
  background: var(--forest);
  padding: 64px 48px 48px;
  text-align: center;
}
.footer-logo {
  font-family: var(--heading-font);
  font-size: 28px;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: white;
  margin-bottom: 12px;
}
.footer-tagline {
  font-size: 14px;
  color: rgba(255,255,255,0.7);
  margin-bottom: 28px;
}
.footer-links {
  display: flex;
  justify-content: center;
  gap: 24px;
  margin-bottom: 32px;
}
.footer-links a {
  font-size: 13px;
  color: rgba(255,255,255,0.6);
  transition: color 0.2s;
}
.footer-links a:hover { color: white; }
.footer-divider {
  width: 100%;
  max-width: 800px;
  margin: 0 auto 32px;
  border: none;
  border-top: 1px solid rgba(255,255,255,0.15);
}
.footer-copyright {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
}

/* ========== NEWSLETTER ========== */
.newsletter {
  margin: 40px 0 32px;
  padding: 40px 0;
  border-top: 1px solid rgba(255,255,255,0.15);
  border-bottom: 1px solid rgba(255,255,255,0.15);
}
.newsletter p {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  margin-bottom: 16px;
  font-weight: 500;
}
.nl-form {
  display: flex;
  gap: 12px;
  max-width: 400px;
  margin: 0 auto;
  flex-wrap: wrap;
  justify-content: center;
}
.nl-form input {
  flex: 1;
  min-width: 200px;
  padding: 12px 16px;
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 6px;
  background: rgba(255,255,255,0.1);
  color: white;
  font-family: var(--body-font);
  font-size: 14px;
  outline: none;
  transition: all 0.3s;
}
.nl-form input::placeholder {
  color: rgba(255,255,255,0.5);
}
.nl-form input:focus {
  border-color: var(--sage);
  background: rgba(255,255,255,0.15);
}
.nl-form button {
  padding: 12px 28px;
  background: var(--sage);
  color: white;
  font-size: 14px;
  font-weight: 500;
  border-radius: 6px;
  transition: all 0.3s;
}
.nl-form button:hover {
  background: #7E9A8C;
  transform: translateY(-2px);
}

/* ========== MODAL ========== */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(45,59,45,0.5);
  backdrop-filter: blur(6px);
  z-index: 2000;
  align-items: center;
  justify-content: center;
}
.modal-overlay.active { display: flex; }
.modal {
  background: white;
  border-radius: 20px;
  padding: 40px 36px;
  max-width: 520px;
  width: 90%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  position: relative;
  animation: modalIn 0.3s ease;
}
@keyframes modalIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
.modal-close {
  position: absolute;
  top: 16px;
  right: 20px;
  font-size: 24px;
  color: var(--deep-sage);
  background: none;
  transition: color 0.2s;
  line-height: 1;
}
.modal-close:hover { color: var(--forest); }

/* Form styles for modal */
.form-group {
  margin-bottom: 20px;
}
.form-group label {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: var(--forest);
  margin-bottom: 6px;
}
.form-group label .required { color: #C0392B; margin-left: 2px; }
.form-input {
  width: 100%;
  border: 1px solid var(--taupe);
  border-radius: 12px;
  padding: 14px 16px;
  font-family: var(--body-font);
  font-size: 15px;
  color: var(--forest);
  background: var(--white);
  transition: all 0.2s;
  outline: none;
}
.form-input:focus {
  border-color: var(--sage);
  box-shadow: 0 0 0 3px rgba(147,169,158,0.15);
}
.form-input::placeholder { color: #B5B0A8; }
.btn-submit {
  width: 100%;
  background: var(--sage);
  color: white;
  font-size: 16px;
  font-weight: 500;
  padding: 16px;
  border-radius: 999px;
  margin-top: 28px;
  transition: background 0.3s;
}
.btn-submit:hover { background: #7E9A8C; }

</style>
</head>
<body>

<!-- ==================== NAVIGATION ==================== -->
<nav class="navbar">
  <a href="index.html" class="navbar-logo">CORE</a>
  <div class="navbar-links">
    <a href="index.html">Home</a>
    <a href="programs.html">Programs</a>
    <a href="equipment.html">Equipment</a>
    <a href="our-story.html" class="active">Founder's Story</a>
    <a href="javascript:void(0)" class="nav-cta" onclick="openModal()">Start Here</a>
  </div>
</nav>

<!-- ==================== FOUNDER HERO ==================== -->
<section class="founder-hero">
  <div class="founder-hero-inner">
    <div class="founder-photo-placeholder">Founder Photo</div>
    <div class="founder-label">OUR FOUNDER</div>
    <h1>Rashi Menda</h1>
    <p class="founder-subtitle">Founder, The Core</p>
  </div>
</section>

<!-- ==================== RASHI'S STORY ==================== -->
<section class="story-section">
  <div class="story-inner">
    <div class="story-text">
      <p>After my pregnancies, I kept hearing, <em>"This is normal."</em><br>
      But I didn't feel like myself.<br>
      My core felt weak. My posture had changed.<br>
      Workouts either pushed me too hard or ignored what I needed.</p>

      <p>In London, I experienced mat-based Pilates built on breath, alignment and deep core strength.<br>
      It wasn't aggressive.<br>
      But it made me feel steady again.</p>

      <div class="story-quote">It made me feel steady again.</div>

      <p>When I came back and couldn't find this in India,<br>
      I built The Core, exactly as I experienced it.<br>
      Because women deserve foundation, not noise.</p>
    </div>
  </div>
</section>

<!-- ==================== CTA SECTION ==================== -->
<section class="cta-hero">
  <div class="cta-hero-inner">
    <h2>Start Your Journey</h2>
    <p>The Core is waiting. Begin your free 3-Day Trial.</p>
    <a href="javascript:void(0)" class="btn-primary" onclick="openModal()">Start Here →</a>
  </div>
</section>

<!-- ==================== FOOTER ==================== -->
<footer class="footer">
  <div class="footer-logo"><img src="images/the-core-logo.png" alt="The Core" style="height:26px;filter:brightness(0) invert(1);margin:0 auto"></div>
  <p class="footer-tagline">Gentle strength, from within.</p>
  <div class="footer-links">
    <a href="index.html">Home</a>
    <a href="programs.html">Programs</a>
    <a href="equipment.html">Equipment</a>
    <a href="our-story.html">Founder's Story</a>
  </div>
  <div class="newsletter">
    <p>Subscribe to our newsletter</p>
    <div class="nl-form">
      <input type="email" placeholder="Enter your email">
      <button type="button">Subscribe</button>
    </div>
  </div>
  <hr class="footer-divider">
  <p class="footer-copyright">&copy; 2026 The Core. All rights reserved.</p>
</footer>

<!-- ==================== MODAL ==================== -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">&times;</button>
    <h3 style="font-family:var(--heading-font);font-size:26px;color:var(--forest);text-align:center;margin-bottom:8px;">Register for The Core Program</h3>
    <p style="font-size:14px;color:var(--deep-sage);text-align:center;margin-bottom:28px;">No payment required. Just your commitment.</p>
    <div class="form-group">
      <label>Full Name <span class="required">*</span></label>
      <input type="text" class="form-input" placeholder="Your full name">
    </div>
    <div class="form-group">
      <label>WhatsApp Number <span class="required">*</span></label>
      <input type="tel" class="form-input" placeholder="+91 00000 00000">
    </div>
    <div class="form-group">
      <label>Email <span class="required">*</span></label>
      <input type="email" class="form-input" placeholder="your@email.com">
    </div>
    <p style="font-size:12px;color:var(--deep-sage);text-align:center;margin-top:8px;">+ Additional questions in the full form</p>
    <button class="btn-submit" style="margin-top:20px;">Begin My 3-Day Trial →</button>
  </div>
</div>

<script>
function openModal() { document.getElementById('modal').classList.add('active'); document.body.style.overflow = 'hidden'; }
function closeModal() { document.getElementById('modal').classList.remove('active'); document.body.style.overflow = ''; }
document.getElementById('modal').addEventListener('click', function(e) { if (e.target === this) closeModal(); });
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
</script>

</body>
</html>
